# LLM（默认本地 LM Studio）
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
MODEL_DAILY=qwen/qwen3.6-27b
MODEL_COMPLEX=qwen/qwen3.6-27b
MODEL_SUMMARY=qwen/qwen3.6-27b

# 备选 LLM（本地 LM Studio 失败时自动切换）
# 多个值用逗号分隔，URL/KEY/名称/模型按顺序一一对应
LLM_FALLBACK_URLS=https://api.deepseek.com/v1,https://api.moonshot.cn/v1
LLM_FALLBACK_KEYS=sk-xxx,sk-yyy
LLM_FALLBACK_NAMES=deepseek,kimi
LLM_FALLBACK_MODELS=deepseek-chat,moonshot-v1-8k

# Agent 迭代预算
AGENT_MAX_ITERATIONS=50
AGENT_MAX_DURATION_SECONDS=180
AGENT_MAX_TOTAL_TOKENS=32000

# 服务端口
PORT=8001

# 数据库（与 Python 服务共用）
DB_HOST=localhost
DB_PORT=5432
DB_USER=family
DB_PASSWORD=salesmind2026
DB_NAME=salesmind

# 数据目录（skills、知识库等）
DATA_DIR=../data

# 资讯看板输出目录（digest.html / knowledge_base.json / articles_*.json 所在目录）
WECHAT_KB_OUTPUT_DIR=../third_party/wechat-digest-skill/output

# 销售政策看板（飞书表格对接）
SALES_POLICY_FILE_PATH=../data/sales_policies.json

# 可选：Python 遗留工具桥接地址
PYTHON_FALLBACK_URL=http://localhost:8000
