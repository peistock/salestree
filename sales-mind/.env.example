# === LLM 配置（OpenAI-compatible）===
# 当前默认 LM Studio 本地模型，也可切换云端
# 切换方式：只改 BASE_URL 和 API_KEY，代码不用动

# LM Studio 本地（当前启用）
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio

# DeepSeek（备选）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REASONING_EFFORT=high

# 百炼 / 通义千问（备选）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kimi（coding 模型，备选）
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 模型选择 ===
# 本地模型（LM Studio）
MODEL_DAILY=qwen/qwen3.6-35b-a3b
MODEL_COMPLEX=qwen/qwen3.6-35b-a3b
MODEL_SUMMARY=qwen/qwen3.6-35b-a3b

# 云端模型备选（DeepSeek / 百炼，切换 BASE_URL 后启用）
# MODEL_DAILY=deepseek-v4-flash
# MODEL_COMPLEX=deepseek-v4-flash
# MODEL_SUMMARY=deepseek-v4-flash

# === 本地模型（上下文压缩 / 摘要）===
# 用于 context_compressor 和敏感数据处理
LOCAL_MODEL_URL=http://127.0.0.1:1234/v1
LOCAL_MODEL_NAME=gemma-4-26b-a4b-it-ud

# === 企业微信（后台获取）===
WECHAT_CORPID=wwxxxxxxxxxxxxxxxx
WECHAT_AGENTID=1000002
WECHAT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WECHAT_TOKEN=xxxxxxxxxxxxxxxx
WECHAT_AESKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 数据库 ===
# 代码本地跑，PostgreSQL 用 Docker port mapping
DB_HOST=localhost
DB_PORT=5432
DB_USER=family
DB_PASSWORD=salesmind2026
DB_NAME=salesmind

# === 系统 ===
WORK_DIR=./data
DATA_DIR=./data
LOG_LEVEL=INFO

# === SearXNG 搜索服务 ===
# 默认本地 Docker 运行的 SearXNG；服务器部署时可改为远程地址（如 Cloudflare Tunnel 域名）
SEARXNG_URL=http://127.0.0.1:8080

# === 出站代理（固定来源 IP，用于企微可信 IP 白名单）===
# 例如通过京东云主机 tinyproxy + SSH 隧道固定出站 IP
# HTTP_PROXY=http://localhost:3128
# HTTPS_PROXY=http://localhost:3128
# 注意：代码已自动设置 NO_PROXY=127.0.0.1,localhost,*.local 保护本地服务

# === 股票数据 API ===
PEISTOCK_API_URL=http://localhost:3457

# === 微信公众号（订阅号，可选）===
# 作为企微的并行通道，老人关注公众号后即可在微信内与刚子对话
# 限制：个人订阅号无客服消息权限（48001），仅能被动回复 XML（5 秒内）
MP_APPID=your_mp_appid
MP_APPSECRET=your_mp_appsecret
MP_TOKEN=your_mp_token

# openid → family member ID 映射（JSON 格式）
# 家人先关注公众号并发一条消息，然后从日志获取 openid 填入
MP_USERS={"openid_xxx":"grandpa","openid_yyy":"grandma","openid_zzz":"dad","openid_www":"mom"}

# === 行业资讯库（wechat-digest）===
# wechat-digest-skill 产出的 knowledge_base.json 路径，留空则使用默认路径
# WECHAT_DIGEST_KB_PATH=./third_party/wechat-digest-skill/output/knowledge_base.json

# 禁用 HuggingFace 联网检查（模型已本地缓存）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# === Embedding 模型配置 ===
# 默认用 sentence-transformers 本地加载 BAAI/bge-small-zh-v1.5（512维）
# 如果想让 LM Studio / 其他 OpenAI 兼容服务提供 embeddings，取消下面注释：
# EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_API_MODEL=BAAI/bge-small-zh-v1.5
